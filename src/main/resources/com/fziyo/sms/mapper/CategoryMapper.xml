<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fziyo.sms.mapper.CategoryMapper">
    <insert id="insert">
        Insert into t_category(name, code) values (#{name}, #{code})
    </insert>
    <delete id="deleteById">
        delete from t_category where id = #{id}
    </delete>
    <select id="list" resultType="com.fziyo.sms.model.entity.Category">
        Select * from t_category
    </select>

</mapper>